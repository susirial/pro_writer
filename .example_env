APP_ENV=development

MODEL_AGENT_PROVIDER=openai
MODEL_AGENT_NAME=doubao-seed-2-0-pro-260215
MODEL_AGENT_API_BASE=https://ark.cn-beijing.volces.com/api/v3/
MODEL_AGENT_API_KEY=your-default-api-key
MODEL_AGENT_TIMEOUT=300
MODEL_AGENT_MAX_RETRIES=3

# Writer（正文生成）示例：GLM-5.1（Z.ai 网关）
MODEL_WRITER_NAME=glm-5.1
MODEL_WRITER_TEMPERATURE=0.8
MODEL_WRITER_API_BASE=https://api.z.ai/api/paas/v4/
MODEL_WRITER_API_KEY=your-writer-api-key
MODEL_WRITER_TIMEOUT=300
MODEL_WRITER_MAX_RETRIES=3

# Reviewer（审阅专员）示例：豆包 2.0
MODEL_REVIEWER_NAME=doubao-seed-2-0-pro-260215
MODEL_REVIEWER_TEMPERATURE=0.3
MODEL_REVIEWER_API_BASE=https://ark.cn-beijing.volces.com/api/v3/
MODEL_REVIEWER_API_KEY=your-reviewer-api-key
MODEL_REVIEWER_TIMEOUT=300
MODEL_REVIEWER_MAX_RETRIES=1

# Reader（读者视角）示例：DeepSeek（示例模型名需与你的网关一致）
MODEL_READER_NAME=deepseek-v3-2-251201
MODEL_READER_TEMPERATURE=0.5
MODEL_READER_API_BASE=https://your-deepseek-gateway/v1/
MODEL_READER_API_KEY=your-reader-api-key
MODEL_READER_TIMEOUT=300
MODEL_READER_MAX_RETRIES=1

# 可选：对 5 个读者分别配置不同模型/Key（例如混用豆包/DeepSeek/GLM）
MODEL_READER_1_NAME=deepseek-v3-2-251201
MODEL_READER_1_API_BASE=https://your-deepseek-gateway/v1/
MODEL_READER_1_API_KEY=your-reader-1-api-key
MODEL_READER_1_TIMEOUT=300
MODEL_READER_1_MAX_RETRIES=1

MODEL_READER_2_NAME=deepseek-v3-2-251201
MODEL_READER_2_API_BASE=https://your-deepseek-gateway/v1/
MODEL_READER_2_API_KEY=your-reader-2-api-key
MODEL_READER_2_TIMEOUT=300
MODEL_READER_2_MAX_RETRIES=1

MODEL_READER_3_NAME=deepseek-v3-2-251201
MODEL_READER_3_API_BASE=https://your-deepseek-gateway/v1/
MODEL_READER_3_API_KEY=your-reader-3-api-key
MODEL_READER_3_TIMEOUT=300
MODEL_READER_3_MAX_RETRIES=1

MODEL_READER_4_NAME=deepseek-v3-2-251201
MODEL_READER_4_API_BASE=https://your-deepseek-gateway/v1/
MODEL_READER_4_API_KEY=your-reader-4-api-key
MODEL_READER_4_TIMEOUT=300
MODEL_READER_4_MAX_RETRIES=1

MODEL_READER_5_NAME=deepseek-v3-2-251201
MODEL_READER_5_API_BASE=https://your-deepseek-gateway/v1/
MODEL_READER_5_API_KEY=your-reader-5-api-key
MODEL_READER_5_TIMEOUT=300
MODEL_READER_5_MAX_RETRIES=1

# Orchestrator（流程编排）示例：豆包 2.0（也可用 DeepSeek/GLM）
MODEL_ORCHESTRATOR_NAME=doubao-seed-2-0-pro-260215
MODEL_ORCHESTRATOR_TEMPERATURE=0.1
MODEL_ORCHESTRATOR_API_BASE=https://ark.cn-beijing.volces.com/api/v3/
MODEL_ORCHESTRATOR_API_KEY=your-orchestrator-api-key
MODEL_ORCHESTRATOR_TIMEOUT=300
MODEL_ORCHESTRATOR_MAX_RETRIES=3
